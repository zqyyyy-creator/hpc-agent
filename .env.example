PARATERA_BASE_URL=your-api-base-url
PARATERA_API_KEY=your-api-key

HPC_HOST=your-hpc-host
HPC_USERNAME=your-hpc-username
HPC_KEY_PATH=/path/to/your/private/key
HPC_REMOTE_WORKDIR=/path/to/remote/workdir
HPC_DEFAULT_PARTITION=your-default-partition
HPC_VASP_REMOTE_WORKDIR=/path/to/vasp/remote/workdir
HPC_VASP_PARTITION=your-vasp-partition
HPC_LOCAL_VASP_IMPORT_DIR=/home/lenovo/vasp-jobs-input
HPC_LOCAL_VASP_JOBS_DIR=/home/lenovo/vasp-jobs
HPC_VASP_SETUP_COMMAND=source /public1/soft/intel/2020u4/compilers_and_libraries_2020.4.304/linux/bin/compilervars.sh intel64
HPC_VASP_COMMAND=mpirun /public1/soft/vasp
HPC_VASP_MODULE=
