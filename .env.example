PARATERA_API_KEY=your-api-key
PARATERA_BASE_URL=https://your-api-base-url
PARATERA_MODEL=DeepSeek-V4-Pro

# Optional external read-only Skills directory.
HPC_AGENT_CUSTOM_SKILLS_DIR=/home/qyz/customize-skills
# Whether to allow trusted external SKILL.md + Python handler execution.
HPC_AGENT_TRUST_EXTERNAL_PYTHON=false
# Max seconds for one external Python handler execution.
HPC_AGENT_EXTERNAL_PYTHON_TIMEOUT_SECONDS=10

HPC_HOST=your-hpc-host
HPC_USERNAME=your-hpc-username
HPC_KEY_PATH=/path/to/your/private/key
HPC_LOCAL_WORKDIR=/path/to/local/hpc-agent-jobs
HPC_REMOTE_WORKDIR=/path/to/remote/hpc-agent-jobs
HPC_DEFAULT_PARTITION=

HPC_LOCAL_VASP_JOBS_INPUT_DIR=/path/to/local/vasp-jobs-input
HPC_LOCAL_VASP_JOBS_OUTPUT_DIR=/path/to/local/vasp-jobs-output
HPC_VASP_REMOTE_INPUT_DIR=/path/to/remote/vasp-hpc-jobs-input
HPC_VASP_REMOTE_OUTPUT_DIR=/path/to/remote/vasp-hpc-jobs-output
HPC_VASP_PARTITION=

# Optional VASP runtime configuration.
# The current BSCC Intel MPI environment exposes mpirun only after this setup.
HPC_VASP_SETUP_COMMAND=source /path/to/vasp/env/setup.sh
HPC_VASP_COMMAND=mpirun /path/to/vasp/bin/vasp_std
HPC_VASP_MODULE=

# Optional Claude Code report generation configuration.
# Claude Code is the CLI used for report generation; this model is the LLM used by VASP reports.
HPC_CLAUDE_CODE_COMMAND=claude
HPC_VASP_REPORT_MODEL=DeepSeek-V4-Pro
HPC_CLAUDE_CODE_TIMEOUT_SECONDS=1800

# Optional MCP deployment configuration for ChatGPT web or other MCP clients.
# These values are used by scripts/start_mcp_http.sh and the systemd template.
HPC_AGENT_MCP_HOST=127.0.0.1
HPC_AGENT_MCP_PORT=8000
HPC_AGENT_MCP_PATH=/mcp
# Tunnel or fixed domain host only, without https:// and without /mcp.
# Example: hpc-agent.example.com or your-subdomain.trycloudflare.com
HPC_AGENT_MCP_ALLOWED_HOST=
HPC_AGENT_MCP_ALLOWED_ORIGIN=
HPC_AGENT_LOG_DIR=/home/qyz/.local/share/hpc-agent/logs
HPC_AGENT_MCP_AUDIT_LOG=/home/qyz/.local/share/hpc-agent/mcp_audit.jsonl

# Guarded MCP execution switches. Keep disabled by default.
# Job submission and VASP output sync require confirm=true plus this variable.
HPC_AGENT_MCP_ENABLE_WRITE=0
# Remote cleanup requires confirm=true plus this variable.
HPC_AGENT_MCP_ENABLE_DESTRUCTIVE=0
